{
    "name": "nyaa-api",
    "version": "3.0.0",
    "description": "Unofficial API wrapper for nyaa.si",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "bun run build",
        "test": "bun test",
        "coverage": "bun test --coverage",
        "lint": "tsc --noEmit"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nglmercer/nyaa-api.git"
    },
    "keywords": [
        "nyaa",
        "torrent",
        "anime",
        "manga",
        "api"
    ],
    "author": "nglmercer",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/nglmercer/nyaa-api/issues"
    },
    "homepage": "https://github.com/nglmercer/nyaa-api#readme",
    "devDependencies": {
        "@types/node": "^20.14.0",
        "happy-dom": "^14.12.0",
        "typescript": "^5.5.0",
        "vite": "^5.4.0",
        "vite-plugin-dts": "^4.0.0",
        "vitest": "^1.6.0"
    },
    "dependencies": {
        "cheerio": "^1.0.0-rc.12"
    }
